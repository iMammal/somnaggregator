# IDE and local environment
.idea/
__pycache__/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/
.venv/
venv/
env/
.env

# Generated analysis outputs
data/interim/*
!data/interim/.gitkeep
data/interim/api_cache/
data/processed/*
!data/processed/.gitkeep
outputs/*
!outputs/.gitkeep

# Real personal health data should not be committed.
data/raw/*
data/raw/api/
!data/raw/.gitkeep
!data/raw/samples/
!data/raw/samples/**/
!data/raw/samples/**/.gitkeep

# Synthetic/de-identified test fixtures are safe to track.
!tests/fixtures/
!tests/fixtures/**
/data/manual_date_mapping_old.csv
/data/manual_date_mapping_paths.csv
/data/manual_metric_overrides.csv
